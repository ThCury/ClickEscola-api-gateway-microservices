  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Salto Gateway → Serviço — p95 (ms)",
      "description": "Tempo entre o gateway receber e o serviço receber a requisição (X-Request-Start → chegada).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "showPoints": "auto" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "legendFormat": "{{service}}",
          "expr": "quantile_over_time(0.95, {container=~\"service-alunos|service-cursos\"} | json | __error__=\"\" | evt=\"trace\" | unwrap gateway_to_service_ms [1m]) by (service)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Processamento no serviço — p95 (ms)",
      "description": "Tempo gasto dentro do microsserviço (alta resolução).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "showPoints": "auto" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "legendFormat": "{{service}}",
          "expr": "quantile_over_time(0.95, {container=~\"service-alunos|service-cursos\"} | json | __error__=\"\" | evt=\"trace\" | unwrap service_ms [1m]) by (service)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requisições roteadas por serviço (req/s)",
      "description": "Throughput visto pelos serviços (linhas de trace).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "legendFormat": "{{service}} {{method}}",
          "expr": "sum by (service, method) (rate({container=~\"service-alunos|service-cursos\"} | json | __error__=\"\" | evt=\"trace\" [1m]))"
        }
      ]
    },
    {
      "id": 4,
